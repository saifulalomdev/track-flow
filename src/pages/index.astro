---
// src/pages/index.astro
import HeroSection from "@/components/landing-page/hero-section";
import PublicHeader from "@/components/landing-page/public-header";
import FeatureSection from "@/components/landing-page/feature-section";
import PricingSection from "@/components/landing-page/pricing-section";
import FAQAndFooterSection from "@/components/landing-page/FAQ-and-footer-section";
import MainLayout from "@/layouts/main.astro";

const session = Astro.locals.session;
const user = Astro.locals.user;

const isUserSignedIn = !!session;
---

<MainLayout>
    <PublicHeader signedIn={isUserSignedIn} client:visible />
    <HeroSection />
    <FeatureSection/>
    <PricingSection/>
    <FAQAndFooterSection client:visible/>
</MainLayout>
