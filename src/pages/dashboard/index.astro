---
import MainLayout from "@/layouts/main.astro";
import DashboardLayout from "@/layouts/dashboard";
import DashboardPage from "@/components/dashboard/dashboard-page";
import { siteService, type Site } from "@/db";
import { getDb } from "@/lib/get-db";
import { actions } from "astro:actions";

const db = getDb(Astro.locals.runtime.env);
let sitesList: Site[] = [];
let dbError = null;

try {
    sitesList = await siteService.findAll(db);
} catch (error) {
    console.error("Failed to load dashboard sites:", error);
    dbError =
        "We encountered a problem reaching our analytics database. Please check back shortly.";
}

const { data, error } = await Astro.callAction(
  actions.getAnalyticsAndSites,
  {                         
    websiteId: "",
    range: { from: "", to: "" },
  }
);

console.log(data, error);
---

<MainLayout>
    <DashboardLayout client:load>
        <DashboardPage
            initialSites={sitesList}
            errorMsg={dbError}
            client:load
        />
    </DashboardLayout>
</MainLayout>
