---
import type { Site } from "@/db";
import MainLayout from "@/layouts/main.astro";
import { getDb } from "@/lib/get-db";
import { DashboardLayout, DashboardPage } from "@/modules/dashboard";
import { dashboardService } from "@/modules/dashboard/dashboard.service";
import { undefined } from "astro:schema";

const db = getDb(Astro.locals.runtime.env);

let dateRange: any = null;
let sites: Site[] = [];
let defaultSiteId;
let dashboardStats: any = "";
let errorMsg;

try {
    const data = await dashboardService.getOverviewData({ db });

    // 2. Map data onto our mutable tracking containers on success
    dateRange = data.dateRange;
    sites = data.sites;
    defaultSiteId = data.defaultSiteId;
    dashboardStats = data.dashboardStats;
} catch (error) {
    // 3. Gracefully trap errors (database drops, worker timeout, network failures)
    console.error("Dashboard overview fetch error:", error);
    errorMsg =
        error instanceof Error
            ? error.message
            : "Failed to load dashboard overview analytics data.";
}
---

<MainLayout>
    <DashboardLayout client:load>
        <DashboardPage
            sites={sites}
            defaultSiteId={defaultSiteId}
            dateRange={dateRange}
            dashboardStats={dashboardStats}
            errorMsg={errorMsg}
            client:load
        />
    </DashboardLayout>
</MainLayout>
