---
import { Button } from "@/components/ui/button";
import DomainEmptyState from "@/components/sites/domain-empty-state";
import SiteCard from "@/components/sites/site-card";
import DashboardLayout from "@/layouts/dashboard";
import MainLayout from "@/layouts/main.astro";
import { Plus } from "lucide-react";
import { websites } from "@/dummy-data/websites";
---

<MainLayout>
    <DashboardLayout client:visible>
        <div class="max-w-6xl mx-auto space-y-10">
            <div
                class="flex flex-col md:flex-row gap-3 justify-between md:items-end"
            >
                <div>
                    <h1 class="text-3xl font-bold tracking-tight">
                        Websites
                    </h1>
                    <p class="text-muted-foreground">
                        Track and manage your websites.
                    </p>
                </div>
                <Button className="gap-2 w-full md:w-auto">
                    <Plus className="w-4 h-4" /> Add New Site
                </Button>
            </div>
            {websites.map(site=> (<SiteCard {...site}/>))}
            <DomainEmptyState />
        </div>
    </DashboardLayout>
</MainLayout>
