---
import { siteService, type Site } from "@/db";
import { DashboardLayout } from "@/modules/dashboard";
import MainLayout from "@/layouts/main.astro";
import { getDb } from "@/lib/get-db";
import { WebsiteManager } from "@/modules/websites";

let initialSites: Site[] = [];
let errorMsg = null;

try {
    const db = getDb(Astro.locals.runtime?.env);
    initialSites = await siteService.findAll(db);
} catch (error: any) {
    errorMsg = error.message || "Something went wrong!";
    console.log((error as any).message);
}
---

<MainLayout>
    <DashboardLayout client:load>
        <WebsiteManager
            initialWebsites={initialSites}
            errorMsg={errorMsg}
            client:load
        />
    </DashboardLayout>
</MainLayout>
