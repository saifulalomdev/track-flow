---
import { Button } from "@/components/ui/button";
import { ArrowUpRight } from "lucide-react";
import "@/styles/global.css";
import MainLayout from "@/layouts/main.astro";
---

<MainLayout>
    <main
        class="h-[calc(100dvh-4rem)] w-full grid place-content-center px-6 py-24 sm:py-32 lg:px-8"
    >
        <div class="text-center">
            <p class="text-8xl font-semibold text-muted-foreground">404</p>
            <h1
                class="mt-4 text-3xl font-bold tracking-tight opacity-80 sm:text-5xl"
            >
                Page not found
            </h1>
            <p class="mt-6 text-base leading-7 text-muted-foreground/80">
                Sorry, we couldn’t find the page you’re looking for.
            </p>
            <div class="mt-10 flex items-center justify-center gap-x-6">
                <a href="/">
                    <Button size="lg"> Go back home </Button>
                </a>
                <a href="/#footer">
                    <Button size="lg" variant="outline">
                        Contact support <ArrowUpRight />
                    </Button>
                </a>
            </div>
        </div>
    </main>
</MainLayout>
