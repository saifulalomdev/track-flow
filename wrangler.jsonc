{
	"main": "./src/worker.ts",
	"name": "trackflow",
	"compatibility_date": "2024-09-23",
	"compatibility_flags": [
		"nodejs_compat_v2",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "trackflow-db",
			"database_id": "893a3b21-f6bf-4881-8337-ac11b0a23214",
			"migrations_dir": "./drizzle"
		}
	],
	"observability": {
		"enabled": true
	}
}